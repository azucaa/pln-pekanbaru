{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.php?$1" }
  ]
}
